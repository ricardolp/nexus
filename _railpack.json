{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "22"
  },
  "steps": {
    "build": {
      "commands": [
        "npm run prisma:generate -w @nexus/backend",
        "npx turbo run build --filter=@nexus/backend"
      ]
    }
  },
  "deploy": {
    "inputs": [{ "step": "build" }],
    "startCommand": "node apps/backend/dist/main.js"
  }
}
