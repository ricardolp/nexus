// --- NFe models ---

model FiscalNfeDocument {
  id                      String                     @id @default(uuid()) @db.Uuid
  organization_id         String                     @db.Uuid
  company_id              String                     @db.Uuid
  direction               fiscal_document_direction
  environment             fiscal_nfe_environment
  status                  fiscal_nfe_document_status @default(draft)
  model                   String                     @default("55") @db.VarChar(2)
  series                  Int
  number                  Int
  access_key              String?                    @db.VarChar(44)
  issuer_cnpj             String                     @db.VarChar(14)
  issuer_name             String?                    @db.VarChar(300)
  recipient_document      String?                    @db.VarChar(14)
  recipient_name          String?                    @db.VarChar(300)
  total_amount            Decimal?                   @db.Decimal(15, 2)
  issued_at               DateTime?
  authorized_at           DateTime?
  cancelled_at            DateTime?
  authorization_protocol  String?                    @db.VarChar(20)
  cancellation_protocol   String?                    @db.VarChar(20)
  sefaz_status_code       String?                    @db.VarChar(10)
  sefaz_status_message    String?
  sap_document_id         String?                    @db.VarChar(128)
  sap_order_id            String?                    @db.VarChar(128)
  idempotency_key         String?                    @db.VarChar(128)
  metadata                Json?
  created_at              DateTime                   @default(now())
  updated_at              DateTime                   @updatedAt
  deleted_at              DateTime?

  organization Organization        @relation(fields: [organization_id], references: [id])
  company      OrganizationCompany @relation(fields: [company_id], references: [id])
  events       FiscalNfeDocumentEvent[]
  timeline     FiscalNfeDocumentTimeline[]
  attachments  FiscalNfeDocumentAttachment[]
  items        FiscalNfeDocumentItem[]
  inboundProcess FiscalNfeInboundProcess?
  sapDocuments FiscalNfeSapDocument[]
  flowInstances FiscalNfeFlowInstance[]

  @@index([company_id, status])
  @@index([company_id, direction, environment])
  @@index([organization_id, direction])
  @@index([organization_id, company_id])
  @@map("fiscal_nfe_documents")
}

model FiscalNfeDocumentEvent {
  id                   String                  @id @default(uuid()) @db.Uuid
  organization_id      String                  @db.Uuid
  document_id          String                  @db.Uuid
  event_type           fiscal_nfe_event_type
  event_status         fiscal_nfe_event_status @default(pending)
  sequence             Int
  sefaz_status_code    String?                 @db.VarChar(10)
  sefaz_status_message String?
  protocol             String?                 @db.VarChar(20)
  correlation_id       String?                 @db.VarChar(128)
  request_summary      Json?
  response_summary     Json?
  error_code           String?                 @db.VarChar(64)
  error_message        String?
  triggered_by_user_id String?                 @db.Uuid
  started_at           DateTime?
  completed_at         DateTime?
  created_at           DateTime                @default(now())
  updated_at           DateTime                @updatedAt
  deleted_at           DateTime?

  organization  Organization                  @relation(fields: [organization_id], references: [id])
  document      FiscalNfeDocument             @relation(fields: [document_id], references: [id])
  triggeredBy   User?                         @relation("NfeDocumentEventTriggeredBy", fields: [triggered_by_user_id], references: [id])
  timeline      FiscalNfeDocumentTimeline[]
  attachments   FiscalNfeDocumentAttachment[]

  @@index([document_id, created_at])
  @@index([document_id, event_type])
  @@index([organization_id, document_id])
  @@map("fiscal_nfe_document_events")
}

model FiscalNfeDocumentTimeline {
  id                String                     @id @default(uuid()) @db.Uuid
  document_id       String                     @db.Uuid
  event_id          String?                    @db.Uuid
  source            fiscal_nfe_timeline_source
  title             String                     @db.VarChar(255)
  message           String?
  metadata          Json?
  created_by_user_id  String?                    @db.Uuid
  created_at        DateTime                   @default(now())
  updated_at        DateTime                   @updatedAt
  deleted_at        DateTime?

  document   FiscalNfeDocument      @relation(fields: [document_id], references: [id])
  event      FiscalNfeDocumentEvent? @relation(fields: [event_id], references: [id])
  createdBy  User?                  @relation("NfeTimelineCreatedBy", fields: [created_by_user_id], references: [id])

  @@index([document_id, created_at])
  @@map("fiscal_nfe_document_timeline")
}

model FiscalNfeDocumentAttachment {
  id               String                     @id @default(uuid()) @db.Uuid
  document_id      String                     @db.Uuid
  event_id         String?                    @db.Uuid
  kind             fiscal_nfe_attachment_kind
  file_name        String                     @db.VarChar(512)
  content_type     String?                    @db.VarChar(128)
  storage_key      String
  content          String?
  size_bytes       BigInt?
  checksum_sha256  String?                    @db.VarChar(64)
  created_at       DateTime                   @default(now())
  updated_at       DateTime                   @updatedAt
  deleted_at       DateTime?

  document FiscalNfeDocument      @relation(fields: [document_id], references: [id])
  event    FiscalNfeDocumentEvent? @relation(fields: [event_id], references: [id])

  @@index([document_id])
  @@index([event_id])
  @@map("fiscal_nfe_document_attachments")
}

model FiscalNfeNumberRange {
