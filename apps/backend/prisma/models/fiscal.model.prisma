model FiscalNfeDocumentItem {
  id                        String                              @id @default(uuid()) @db.Uuid
  document_id               String                              @db.Uuid
  line_number               Int
  prod_codigo               String                              @db.VarChar(60)
  descricao                 String                              @db.VarChar(500)
  ncm                       String                              @default("") @db.VarChar(8)
  cfop                      String                              @default("") @db.VarChar(4)
  qty                       Decimal                             @db.Decimal(15, 4)
  uom                       String                              @default("UN") @db.VarChar(10)
  valor_total               Decimal                             @db.Decimal(15, 2)
  x_ped                     String?                             @db.VarChar(60)
  n_item_ped                String?                             @db.VarChar(20)
  pedido_validation_status  fiscal_nfe_pedido_validation_status @default(pending)
  pedido_validation_message String?
  sap_order_number          String?                             @db.VarChar(20)
  sap_order_item            String?                             @db.VarChar(10)
  created_at                DateTime                            @default(now())
  updated_at                DateTime                            @updatedAt
  deleted_at                DateTime?

  document     FiscalNfeDocument    @relation(fields: [document_id], references: [id])
  sapDocuments FiscalNfeSapDocument[]

  @@unique([document_id, line_number])
  @@index([document_id])
  @@map("fiscal_nfe_document_items")
}

model FiscalNfeInboundProcess {
  document_id                  String                    @id @db.Uuid
  inbound_status               fiscal_nfe_inbound_status @default(xml_imported)
  status_changed_at            DateTime                  @default(now())
  sefaz_validated_at           DateTime?
  pedido_validated_at          DateTime?
  delivery_created_at          DateTime?
  portaria_confirmed_at        DateTime?
  portaria_confirmed_by_user_id String?                  @db.Uuid
  migo_completed_at            DateTime?
  miro_completed_at            DateTime?
  rejected_at                  DateTime?
  rejected_by_user_id          String?                   @db.Uuid
  rejection_reason             String?
  alert_code                   String?                   @db.VarChar(64)
  alert_message                String?
  correlation_id               String?                   @db.VarChar(128)
  created_at                   DateTime                  @default(now())
  updated_at                   DateTime                  @updatedAt
  deleted_at                   DateTime?

  document              FiscalNfeDocument @relation(fields: [document_id], references: [id])
  portariaConfirmedBy   User?             @relation("NfeInboundPortariaConfirmedBy", fields: [portaria_confirmed_by_user_id], references: [id])
  rejectedBy            User?             @relation("NfeInboundRejectedBy", fields: [rejected_by_user_id], references: [id])

  @@map("fiscal_nfe_inbound_process")
}

model FiscalNfeSapDocument {
  id            String                         @id @default(uuid()) @db.Uuid
  document_id   String                         @db.Uuid
  item_id       String?                        @db.Uuid
  document_type fiscal_nfe_sap_document_type
