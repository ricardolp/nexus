  pedido_validated_at          DateTime?
  delivery_created_at          DateTime?
  portaria_confirmed_at        DateTime?
  portaria_confirmed_by_user_id String?                   @db.Uuid
  migo_completed_at            DateTime?
  miro_completed_at            DateTime?
  rejected_at                  DateTime?
  rejected_by_user_id          String?                    @db.Uuid
  rejection_reason             String?
  alert_code                   String?                    @db.VarChar(64)
  alert_message                String?
  correlation_id               String?                    @db.VarChar(128)
  created_at                   DateTime                   @default(now())
  updated_at                   DateTime                   @updatedAt
  deleted_at                   DateTime?

  document              FiscalNfseDocument @relation(fields: [document_id], references: [id])
  portariaConfirmedBy   User?              @relation("NfseInboundPortariaConfirmedBy", fields: [portaria_confirmed_by_user_id], references: [id])
  rejectedBy            User?              @relation("NfseInboundRejectedBy", fields: [rejected_by_user_id], references: [id])

  @@map("fiscal_nfse_inbound_process")
}

model FiscalNfseSapDocument {
  id            String                          @id @default(uuid()) @db.Uuid
  document_id   String                          @db.Uuid
  item_id       String?                         @db.Uuid
  document_type fiscal_nfse_sap_document_type
  doc_number    String                          @db.VarChar(20)
  item_number   String?                         @db.VarChar(10)
  fiscal_year   String?                         @db.VarChar(4)
  status        fiscal_nfse_sap_document_status @default(pending)
  raw_response  Json?
  created_at    DateTime                        @default(now())
  updated_at    DateTime                        @updatedAt
  deleted_at    DateTime?

  document FiscalNfseDocument    @relation(fields: [document_id], references: [id])
  item     FiscalNfseDocumentItem? @relation(fields: [item_id], references: [id])

  @@index([document_id])
  @@index([document_id, document_type])
  @@map("fiscal_nfse_sap_documents")
}

// --- NFe flow config models ---

model FiscalNfeFlowConfig {
  id              String                      @id @default(uuid()) @db.Uuid
  organization_id String                      @db.Uuid
  company_id      String?                     @db.Uuid
  model           String                      @db.VarChar(20)
  name            String                      @db.VarChar(200)
  version         String                      @db.VarChar(20)
  active          Boolean                     @default(false)
  status          fiscal_nfe_flow_config_status @default(draft)
  created_by      String?                     @db.Uuid
  updated_by      String?                     @db.Uuid
  created_at      DateTime                    @default(now())
  updated_at      DateTime                    @updatedAt
  deleted_at      DateTime?

  organization Organization         @relation(fields: [organization_id], references: [id])
  company      OrganizationCompany? @relation(fields: [company_id], references: [id])
  createdBy    User?                @relation("NfeFlowConfigCreatedBy", fields: [created_by], references: [id])
  updatedBy    User?                @relation("NfeFlowConfigUpdatedBy", fields: [updated_by], references: [id])
  steps        FiscalNfeFlowStep[]
  edges        FiscalNfeFlowEdge[]
  auditLogs    FiscalNfeFlowAuditLog[]
  instances    FiscalNfeFlowInstance[]

  @@unique([organization_id, company_id, model, version])
  @@index([organization_id, company_id, model, status])
  @@map("fiscal_nfe_flow_configs")
}

model FiscalNfeFlowStep {
  id              String                  @id @default(uuid()) @db.Uuid
  flow_config_id  String                  @db.Uuid
  step_key        String                  @db.VarChar(64)
  name            String                  @db.VarChar(200)
  sequence        Int
  active          Boolean                 @default(true)
  type            fiscal_nfe_flow_step_type
  config          Json                    @default("{}")
  position_x      Float                   @default(0)
  position_y      Float                   @default(0)
  created_at      DateTime                @default(now())
  updated_at      DateTime                @updatedAt
  deleted_at      DateTime?

  flowConfig       FiscalNfeFlowConfig @relation(fields: [flow_config_id], references: [id], onDelete: Cascade)
  outgoingEdges    FiscalNfeFlowEdge[] @relation("FlowEdgeSource")
  incomingEdges    FiscalNfeFlowEdge[] @relation("FlowEdgeTarget")
  currentInstances FiscalNfeFlowInstance[] @relation("FlowInstanceCurrentStep")

  @@index([flow_config_id, sequence])
  @@map("fiscal_nfe_flow_steps")
}

model FiscalNfeFlowEdge {
  id                    String                       @id @default(uuid()) @db.Uuid
  flow_config_id        String                       @db.Uuid
  source_step_id        String                       @db.Uuid
  target_step_id        String                       @db.Uuid
  condition_type        fiscal_nfe_flow_edge_condition
  condition_expression  Json?
  created_at            DateTime                     @default(now())
  updated_at            DateTime                     @updatedAt
  deleted_at            DateTime?

  flowConfig FiscalNfeFlowConfig @relation(fields: [flow_config_id], references: [id], onDelete: Cascade)
  sourceStep FiscalNfeFlowStep   @relation("FlowEdgeSource", fields: [source_step_id], references: [id], onDelete: Cascade)
  targetStep FiscalNfeFlowStep   @relation("FlowEdgeTarget", fields: [target_step_id], references: [id], onDelete: Cascade)

  @@index([flow_config_id])
  @@map("fiscal_nfe_flow_edges")
}

model FiscalNfeFlowAuditLog {
  id              String   @id @default(uuid()) @db.Uuid
  flow_config_id  String   @db.Uuid
  version         String   @db.VarChar(20)
  user_id         String?  @db.Uuid
  action          String   @db.VarChar(64)
  step_key        String?  @db.VarChar(64)
  before          Json?
  after           Json?
  reason          String?
  created_at      DateTime @default(now())

  flowConfig FiscalNfeFlowConfig @relation(fields: [flow_config_id], references: [id], onDelete: Cascade)
  user       User?               @relation("NfeFlowAuditLogUser", fields: [user_id], references: [id])

  @@index([flow_config_id, created_at])
  @@map("fiscal_nfe_flow_audit_logs")
}

model FiscalNfeFlowInstance {
  id               String                        @id @default(uuid()) @db.Uuid
  flow_config_id   String                        @db.Uuid
  document_id      String                        @db.Uuid
  model            String                        @db.VarChar(20)
  status           fiscal_nfe_flow_instance_status @default(draft)
  current_step_id  String?                       @db.Uuid
  started_at       DateTime                      @default(now())
  finished_at      DateTime?
  created_at       DateTime                      @default(now())
  updated_at       DateTime                      @updatedAt
  deleted_at       DateTime?

  flowConfig   FiscalNfeFlowConfig @relation(fields: [flow_config_id], references: [id])
  document     FiscalNfeDocument   @relation(fields: [document_id], references: [id])
  currentStep  FiscalNfeFlowStep?  @relation("FlowInstanceCurrentStep", fields: [current_step_id], references: [id])
  executions   FiscalNfeFlowStepExecution[]

  @@index([document_id])
  @@index([flow_config_id, status])
  @@map("fiscal_nfe_flow_instances")
}

model FiscalNfeFlowStepExecution {
  id          String                              @id @default(uuid()) @db.Uuid
  instance_id String                              @db.Uuid
  step_key    String                              @db.VarChar(64)
  status      fiscal_nfe_flow_step_execution_status @default(pending)
  message     String?
  payload     Json?
  started_at  DateTime?
  finished_at DateTime?
  created_at  DateTime                            @default(now())
  updated_at  DateTime                            @updatedAt

  instance FiscalNfeFlowInstance @relation(fields: [instance_id], references: [id], onDelete: Cascade)

  @@index([instance_id, step_key])
  @@map("fiscal_nfe_flow_step_executions")
}
