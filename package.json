{
  "name": "@nexus/root",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "railway:build:backend": "turbo run build --filter=@nexus/backend...",
    "railway:build:frontend": "turbo run build --filter=@nexus/frontend",
    "railway:start:backend": "npm run start:prod --workspace=@nexus/backend",
    "railway:start:frontend": "npm run start --workspace=@nexus/frontend"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "npm@11.6.1",
  "workspaces": [
    "apps/*",
    "modules/*",
    "packages/*"
  ],
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.14"
  }
}
